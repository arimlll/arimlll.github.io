---
const { class: className } = Astro.props;
---
<a href="/" class:list={["logo", className]} aria-label="Ariml Home">
  <svg width="32" height="32" viewBox="0 0 125 125" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient x1="0" y1="1" x2="1" y2="0" id="logo-grad">
        <stop offset="0.34%" stop-color="#F8C822" />
        <stop offset="100%" stop-color="#FAE800" />
      </linearGradient>
    </defs>
    <path d="M62.5 0C97.0225 0 125 27.9775 125 62.5C125 97.0225 97.0225 125 62.5 125C27.9775 125 0 97.0225 0 62.5C0 27.9775 27.9775 0 62.5 0Z" fill="url(#logo-grad)" />
  </svg>
  <span class="logo-text">Ariml</span>
</a>

<style>
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
  }

  .logo:hover {
    color: var(--color-text);
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
</style>
