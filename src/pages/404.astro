---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="404 - 页面未找到">
  <div class="not-found">
    <h1>404</h1>
    <p>页面未找到</p>
    <a href="/" class="home-link">返回首页 &rarr;</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 6rem 0;
  }

  .not-found h1 {
    font-size: 5rem;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .not-found p {
    color: var(--color-text-secondary);
    font-size: 1.25rem;
    margin-bottom: 2rem;
  }

  .home-link {
    font-size: 1rem;
    color: var(--color-accent);
  }
</style>
